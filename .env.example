# Variables d'environnement — exemple
# Copier en .env.dev / .env.test / .env.preprod / .env.prod selon l'environnement.

# ─── Django / Wagtail ──────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-in-production
DEBUG=True
# Prod : culturall-website.nickorp.com,cultur-all.org
ALLOWED_HOSTS=localhost,127.0.0.1
# Requis en prod pour que les POST admin passent le check CSRF derrière un
# reverse proxy HTTPS. Liste d'origines (schéma inclus), séparées par des virgules.
# Prod : https://culturall-website.nickorp.com,https://cultur-all.org
CSRF_TRUSTED_ORIGINS=
# ⚠️ DATABASE_URL doit contenir le MÊME password que POSTGRES_PASSWORD ci-dessous.
# Si tu changes l'un, change l'autre. Caractères spéciaux dans le password :
# URL-encode (^ → %5E, # → %23, @ → %40, : → %3A, / → %2F).
DATABASE_URL=postgres://app_user:app_pass@postgres:5432/app_db

# ─── Cloudflare Turnstile (anti-bots du formulaire de contact) ─
# Laisser vide en dev/CI : la vérification est alors désactivée.
# En prod, renseigner les deux clés depuis le dashboard Cloudflare Turnstile.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ─── Plausible Analytics (auto-hébergé, sans cookie) ───────────
# Mesure d'audience du site (visiteurs uniques + pages vues par page).
# Le script n'est injecté que pour les visiteurs anonymes : les utilisateurs
# connectés sont exclus des statistiques. Laisser vide désactive la mesure.
# Voir docs/analytics-plausible.md pour le déploiement de l'instance Plausible.
#   PLAUSIBLE_DOMAIN     : data-domain du site suivi
#   PLAUSIBLE_SCRIPT_URL : URL du script servi par l'instance Plausible
# Prod :
#   PLAUSIBLE_DOMAIN=cultur-all.org
#   PLAUSIBLE_SCRIPT_URL=https://stats.cultur-all.org/js/script.js
PLAUSIBLE_DOMAIN=
PLAUSIBLE_SCRIPT_URL=

# ─── PostgreSQL ────────────────────────────────────────────────
POSTGRES_DB=app_db
POSTGRES_USER=app_user
# ⚠️ Si le password contient un '#', il DOIT être quoté ("..."), sinon docker
# compose interprète tout après le '#' comme un commentaire et le tronque.
# Recommandation : utiliser un password alphanumérique pour éviter ces pièges.
POSTGRES_PASSWORD=app_pass

# ─── MinIO (S3-compatible, self-hosted) ────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-in-production
# Endpoint INTERNE (Django ↔ MinIO via le réseau docker compose)
MINIO_ENDPOINT_URL=http://minio:9000
MINIO_BUCKET_NAME=media
# Endpoint PUBLIC (URLs des médias servies au navigateur via Traefik)
# Dev    : http://localhost:9000
# Prod   : https://media.cultur-all.org
MINIO_PUBLIC_URL=http://localhost:9000

# ─── Next.js ───────────────────────────────────────────────────
# URL publique de l'API, utilisée par le code client (navigateur).
# Dev    : http://localhost:8000
# TNR    : (vide — URLs relatives, évite les problèmes DNS du navigateur headless)
# Prod   : https://culturall-website.nickorp.com
NEXT_PUBLIC_API_URL=http://localhost:8000
# URL interne de l'API, utilisée par le middleware SSR de Next.js.
# Prioritaire sur NEXT_PUBLIC_API_URL côté serveur (voir frontend/middleware.ts).
# Dev    : (non requis, NEXT_PUBLIC_API_URL suffit)
# TNR    : http://nginx
# Prod   : (non requis, NEXT_PUBLIC_API_URL suffit)
INTERNAL_API_URL=
NODE_ENV=development

# ─── CI/CD (production uniquement) ─────────────────────────────
# Renseigné par .github/workflows/deploy-prod.yml ; tag d'image à déployer
REGISTRY=ghcr.io/nicolasdeclerck/culturall-website
IMAGE_TAG=latest

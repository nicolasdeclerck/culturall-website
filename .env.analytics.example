# Variables d'environnement — stack Plausible (mesure d'audience auto-hébergée)
# Copier en .env.analytics et remplir les secrets avant de lancer
# docker-compose.analytics.yml. Ce fichier NE concerne QUE l'instance
# Plausible ; la config côté site vit dans .env.prod (PLAUSIBLE_DOMAIN /
# PLAUSIBLE_SCRIPT_URL).

# ─── Plausible ─────────────────────────────────────────────────
# URL publique du tableau de bord (doit correspondre au routeur Traefik).
BASE_URL=https://stats-culturall.nickorp.com

# Clés secrètes — générer des valeurs fortes et uniques :
#   SECRET_KEY_BASE : openssl rand -base64 48
#   TOTP_VAULT_KEY  : openssl rand -base64 32
SECRET_KEY_BASE=change-me-openssl-rand-base64-48
TOTP_VAULT_KEY=change-me-openssl-rand-base64-32

# Inscription des comptes Plausible. Valeurs : false | true | invite_only.
# ⚠️ PREMIER LANCEMENT : laisser « false » pour pouvoir créer le compte admin
#    via l'UI (https://stats-culturall.nickorp.com). Une fois le compte créé,
#    repasser à « true » puis relancer `up -d` pour verrouiller les inscriptions.
DISABLE_REGISTRATION=false

# ─── PostgreSQL interne de Plausible ───────────────────────────
# Mot de passe de la base de métadonnées Plausible (utilisé aussi dans
# DATABASE_URL côté service `plausible`).
# ⚠️ Utiliser un mot de passe SANS caractères spéciaux (ex. `openssl rand -hex 24`) :
#    il est injecté tel quel dans DATABASE_URL, donc `/ + @ :` casseraient l'URL.
PLAUSIBLE_DB_PASSWORD=change-me-openssl-rand-hex-24
